{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "articles.graduateshub.co.za"
        }
      ],
      "destination": "https://graduateshub.co.za/blog/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/blog",
      "destination": "https://blog.graduateshub.co.za"
    },
    {
      "source": "/blog/:path*",
      "destination": "https://blog.graduateshub.co.za/:path*"
    }
  ]
}