{
  "rewrites": [
    {
      "source": "/blog/wp-admin",
      "destination": "https://blog.graduateshub.co.za/wp-admin"
    },
    {
      "source": "/blog/wp-admin/:path*",
      "destination": "https://blog.graduateshub.co.za/wp-admin/:path*"
    },
    {
      "source": "/blog/wp-login.php",
      "destination": "https://blog.graduateshub.co.za/wp-login.php"
    },
    {
      "source": "/blog/:path*",
      "destination": "https://blog.graduateshub.co.za/:path*"
    }
  ]
}